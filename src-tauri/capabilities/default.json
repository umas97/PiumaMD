{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-read",
      "scope": ["**/*", "/"]
    },
    {
      "identifier": "fs:allow-write",
      "scope": ["**/*", "/"]
    },
    {
      "identifier": "fs:allow-exists",
      "scope": ["**/*", "/"]
    }
  ]
}
