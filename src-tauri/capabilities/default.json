{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "window-state:default",
    {
      "identifier": "fs:default",
      "scope": ["$HOME/**"]
    }
  ]
}
